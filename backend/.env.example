# App Config
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database Configuration (MySQL)
# Sửa lại Username "root" và Mật khẩu "1234567890" tùy theo máy Local của bạn
# "maverik_store" là tên Database bạn cần tạo trống trước bằng XAMPP / MySQL Workbench
DATABASE_URL=mysql://root:1234567890@localhost:3306/maverik_store

# JWT Setup
JWT_SECRET=maverik_studio_secret_key_123
JWT_EXPIRE=7d

# Bcrypt Config
BCRYPT_ROUNDS=10

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging Options
LOG_LEVEL=debug
